# memdesk — copy to .env and fill in. .env is gitignored.
#
# memdesk is hybrid: it uses the cloud endpoint first and falls back to a
# local Ollama model when cloud doesn't answer. Pin one with "provider" in
# config.json ("auto" | "local" | "cloud").

# --- cloud (arkor). The default. ---
OPENAI_BASE_URL=https://in.arkor.app/v1
OPENAI_API_KEY=your_key_here
VISION_MODEL=gemma-4-31B-it

# --- local (Ollama) fallback. Defaults shown; omit to accept them. ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:e2b
